{
  "name": "@bitremit/bots",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "dev:whatsapp": "tsx --env-file=../../.env.local whatsapp/index.ts",
    "dev:telegram": "tsx --env-file=../../.env.local telegram/index.ts",
    "build": "pnpm --filter @bitremit/database run db:generate && tsc",
    "start": "tsx whatsapp/index.ts"
  },
  "dependencies": {
    "@bitremit/database": "workspace:*",
    "tsx": "^4.19.2",
    "@grammyjs/conversations": "^2.1.1",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "grammy": "^1.42.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "twilio": "^5.13.1",
    "web3": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  }
}
