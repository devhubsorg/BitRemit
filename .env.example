# =============================================================================
# BitRemit — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# Sections: Database · Redis/Queue · Blockchain/Contracts · Auth · Twilio/SMS
#           · Off-ramp URLs · App
# =============================================================================


# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string — provisioned on Railway (or local for dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/bitremit?sslmode=require"

# Direct (non-pooled) connection — used by Prisma migrations and `prisma generate`
DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@HOST:PORT/bitremit?sslmode=require"


# =============================================================================
# REDIS / QUEUE
# =============================================================================

# Upstash Redis REST URL — used by BullMQ job queues and SIWE nonce storage
UPSTASH_REDIS_URL="https://YOUR_UPSTASH_INSTANCE.upstash.io"

# Upstash Redis REST auth token — keep secret; never expose to the browser
UPSTASH_REDIS_TOKEN="YOUR_UPSTASH_TOKEN_HERE"


# =============================================================================
# BLOCKCHAIN / CONTRACTS
# =============================================================================

# Mezo testnet JSON-RPC endpoint (Chain ID 31611) — used by Foundry fork tests + indexer
MEZO_TESTNET_RPC_URL="https://rpc.test.mezo.org"

# Mezo mainnet JSON-RPC endpoint — leave empty until mainnet launch
MEZO_MAINNET_RPC_URL="https://rpc.mezo.org"

# Deployed address of BitRemitVault.sol on Mezo testnet
NEXT_PUBLIC_VAULT_ADDRESS="0xYOUR_VAULT_CONTRACT_ADDRESS"

# Deployed address of RemittanceRouter.sol on Mezo testnet
NEXT_PUBLIC_ROUTER_ADDRESS="0xYOUR_ROUTER_CONTRACT_ADDRESS"

# Deployed address of RecipientRegistry.sol on Mezo testnet
NEXT_PUBLIC_REGISTRY_ADDRESS="0xYOUR_REGISTRY_CONTRACT_ADDRESS"

# EVM chain ID surfaced to the frontend — Mezo testnet = 31611
NEXT_PUBLIC_CHAIN_ID="31611"

# Block number from which the blockchain indexer starts scanning events (avoids scanning genesis)
INDEXER_START_BLOCK="0"

# Private key of the deployer/relayer wallet — NEVER commit a funded key; use a burner for dev
DEPLOYER_PRIVATE_KEY="0xYOUR_DEPLOYER_PRIVATE_KEY"


# =============================================================================
# AUTH
# =============================================================================

# Secret used to sign JWT tokens (SIWE auth flow) — minimum 32 random bytes, base64-encoded
JWT_SECRET="YOUR_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS"

# JWT token expiry duration in seconds (e.g. 86400 = 24 hours)
JWT_EXPIRY_SECONDS="86400"

# Allowed origins for SIWE message domain validation (comma-separated if multiple)
SIWE_DOMAIN="localhost:3000"


# =============================================================================
# TWILIO / SMS
# =============================================================================

# Twilio Account SID — found in the Twilio Console dashboard
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"

# Twilio Auth Token — secret credential for Twilio REST API calls
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"

# Twilio phone number used as SMS / WhatsApp sender (E.164 format)
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# Twilio WhatsApp sandbox number (prefix with whatsapp: for sandbox testing)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Webhook URL Twilio calls when a WhatsApp message is received
TWILIO_WEBHOOK_URL="https://YOUR_RAILWAY_BOT_URL/webhooks/whatsapp"


# =============================================================================
# OFF-RAMP URLS
# =============================================================================

# Base URL of the mock (or live) M-Pesa off-ramp server running on Railway
MPESA_API_URL="https://YOUR_RAILWAY_MPESA_MOCK_URL"

# API key for authenticating requests to the M-Pesa off-ramp service
MPESA_API_KEY="YOUR_MPESA_API_KEY"

# Base URL of the mock (or live) GCash off-ramp server running on Railway
GCASH_API_URL="https://YOUR_RAILWAY_GCASH_MOCK_URL"

# API key for authenticating requests to the GCash off-ramp service
GCASH_API_KEY="YOUR_GCASH_API_KEY"

# Base URL of the mock (or live) MTN Mobile Money off-ramp server running on Railway
MTNMOMO_API_URL="https://YOUR_RAILWAY_MTNMOMO_MOCK_URL"

# API key for authenticating requests to the MTN MoMo off-ramp service
MTNMOMO_API_KEY="YOUR_MTNMOMO_API_KEY"

# Shared secret used to validate signed webhook callbacks from off-ramp providers
OFFRAMP_WEBHOOK_SECRET="YOUR_OFFRAMP_WEBHOOK_SECRET"


# =============================================================================
# APP
# =============================================================================

# Canonical public URL of the deployed Next.js app — no trailing slash
NEXT_PUBLIC_APP_URL="https://bitremit.app"

# Node environment — "development" | "test" | "production"
NODE_ENV="development"

# Log level for server-side logging (debug | info | warn | error)
LOG_LEVEL="info"

# Port the Next.js dev server listens on (Vercel ignores this; Railway uses it for bots)
PORT="3000"

# Telegram Bot API token — issued by @BotFather on Telegram
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Internal shared secret between the Next.js API and the BullMQ worker processes
WORKER_API_SECRET="YOUR_RANDOM_INTERNAL_WORKER_SECRET"
