# ==========================================
# Database (Railway PostgreSQL)
# ==========================================
# Connection string for Prisma
DATABASE_URL=postgresql://user:password@containers-us-west-XX.railway.app:5432/railway

# ==========================================
# Redis/Queue (Upstash)
# ==========================================
# Redis connection URL for BullMQ and Upstash Redis
UPSTASH_REDIS_URL=rediss://default:YOUR_PASSWORD_HERE@YOUR_ENDPOINT.upstash.io:6379
# Redis token for HTTP requests (if needed)
UPSTASH_REDIS_TOKEN=YOUR_TOKEN_HERE

# ==========================================
# Blockchain/Contracts
# ==========================================
# Testnet RPC for Mezo (Chain ID 31611)
MEZO_RPC_URL=https://rpc.test.mezo.org
# Backup RPC for reliability
MEZO_RPC_BACKUP=https://backup.rpc.test.mezo.org
# The block number where our contracts were first deployed (for indexing)
DEPLOY_BLOCK_NUMBER=123456
# Funded testnet private key or mnemonic for backend transactions
BACKEND_SIGNER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
# Proxy addresses for our contracts
NEXT_PUBLIC_VAULT_ADDRESS=0x_VAULT_ADDRESS
NEXT_PUBLIC_ROUTER_ADDRESS=0x_ROUTER_ADDRESS
NEXT_PUBLIC_REGISTRY_ADDRESS=0x_REGISTRY_ADDRESS
# Verified MUSD stablecoin address on Mezo Testnet
NEXT_PUBLIC_MUSD_ADDRESS=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
# The same RPC for frontend consumption
NEXT_PUBLIC_MEZO_RPC=https://rpc.test.mezo.org

# ==========================================
# Auth (SIWE / JWT)
# ==========================================
# Secret used for signing JWT tokens
JWT_SECRET=YOUR_RANDOM_SECRET_KEY

# ==========================================
# Twilio/SMS
# ==========================================
# Twilio Account SID
TWILIO_ACCOUNT_SID=AC_YOUR_TWILIO_SID
# Twilio Auth Token
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
# Twilio Phone Number used as sender
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# Telegram Bot
# ==========================================
# Token provided by BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# ==========================================
# Off-ramp URLs
# ==========================================
# Base URL for the MPesa Mock Server
MPESA_MOCK_URL=http://localhost:3001
# Base URL for the GCash Mock Server
GCASH_MOCK_URL=http://localhost:3002
# Base URL for the MTN MoMo Mock Server
MTNMOMO_MOCK_URL=http://localhost:3003

# ==========================================
# App
# ==========================================
# Main frontend base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
